[
    {
        "id": "s0-001",
        "title": "貓在公園",
        "arc": "stray",
        "perspective": "cat",
        "coreConcepts": ["u00-0002", "u00-0003", "u00-0004", "u00-0001", "u00-0005"],
        "lines": [
            "今天是白天。",
            "我在公園。",
            "公園里有貓。",
            "貓在樹下。",
            "我看貓。",
            "貓看我。",
            "我有手機。",
            "我拿手機。",
            "我看手機。",
            "朋友來公園。",
            "朋友看貓。",
            "貓走。",
            "貓去樹里。",
            "我找貓。",
            "我看水。",
            "水在公園里。",
            "今天是好天。",
            "我喜欢貓。"
        ],
        "audio": "s0-001.mp3"
    }
]

    